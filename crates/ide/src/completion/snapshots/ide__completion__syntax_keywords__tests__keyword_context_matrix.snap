# prefix filters
ModuleMember prefix "al": all_match=true ["always"]
ModuleMember prefix "lo": all_match=true ["localparam"]
GenerateMember prefix "as": all_match=true ["assign"]
SpecifyItem prefix "sp": all_match=true ["specparam"]
ConfigHeaderItem prefix "de": all_match=true ["design"]
ConfigRule prefix "de": all_match=true ["default"]
BlockItem prefix "re": all_match=true ["real", "realtime", "reg", "release", "repeat"]
Statement prefix "re": all_match=true ["release", "repeat"]
AnsiPortItem prefix "wir": all_match=true ["wire"]
ParameterPortListItem prefix "para": all_match=true ["parameter"]
